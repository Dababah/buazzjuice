# ─── BUAZZZ JUICE — Environment Variables ────────────────────────────────────
# Copy file ini menjadi .env.local dan isi semua value yang diperlukan
# JANGAN commit file .env.local ke git!

# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# Ambil dari: https://neon.tech → Dashboard → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate random string panjang, contoh: openssl rand -base64 32
JWT_SECRET="ganti_dengan_random_string_yang_sangat_panjang_dan_aman_minimal_32_karakter"

# ─── VERCEL BLOB (Upload foto QRIS & produk) ──────────────────────────────────
# Ambil dari: Vercel Dashboard → Storage → Blob → .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxx"

# ─── OPENAI (AI Copilot untuk rekap konsinyasi) ───────────────────────────────
# Ambil dari: https://platform.openai.com/api-keys
# Opsional — fitur AI tidak akan berfungsi tanpa ini, tapi app tetap jalan
OPENAI_API_KEY="sk-proj-xxxxxxxxxx"

# ─── APP CONFIG ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Nomor WhatsApp admin untuk tombol order di landing page
# Format: 62 + nomor tanpa 0 di depan (contoh: 6281234567890)
NEXT_PUBLIC_ADMIN_WA_NUMBER="6281234567890"
